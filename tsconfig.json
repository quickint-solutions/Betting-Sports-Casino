{
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "classic",
    "target": "es6",
    "removeComments": true,
    "sourceMap": true,
    "outDir": "./.generated/js/",
    "declaration": false,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "noEmitOnError": false,
    "rootDir": "."
  },
  "exclude": [
    "node_modules",
    "public/app/**/*.d.ts",
    "test/**/*.d.ts"
  ]
}